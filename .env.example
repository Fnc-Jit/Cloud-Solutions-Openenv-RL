# ============================================================
# CloudFinOps-Env — Environment Configuration
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. Run:  python inference.py
#
# That's it. Everything reads from this file automatically.
# ============================================================

# ── Required Environment Variables (Hackathon Mandatory) ─────
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=openai/gpt-4o
HF_TOKEN=hf_your_token_here

# ── Optional Overrides ────────────────────────────────────────
# ENV_BASE_URL=http://localhost:8000
# STEP_DELAY_S=2.0
