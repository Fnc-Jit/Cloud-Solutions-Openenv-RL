# ============================================================
# CloudFinOps-Env — Environment Variables Reference
# ============================================================
# These variables must be exported in your shell or passed via
# docker run -e flags. This file is NOT auto-loaded by the
# inference script — it is only a reference template.
#
# Usage (shell):
#   export API_BASE_URL=https://router.huggingface.co/v1
#   export MODEL_NAME=openai/gpt-4o
#   export HF_TOKEN=hf_your_token_here
#   python inference.py
#
# Usage (Docker):
#   docker run -e API_BASE_URL=... -e MODEL_NAME=... -e HF_TOKEN=... ...
# ============================================================

# ── Mandatory Variables ──────────────────────────────────────
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=openai/gpt-4o
HF_TOKEN=hf_your_token_here

# ── Optional: Groq Testing ──────────────────────────────────
# Set LLM_PROVIDER=groq to use Groq instead of HuggingFace.
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_your_groq_api_key_here
# GROQ_MODEL_NAME=llama-3.3-70b-versatile

# ── Optional: Environment Server URL ────────────────────────
# ENV_BASE_URL=http://localhost:8000
